# ============================================================
# Alshaya AI Resume Benchmarking Platform - Environment Sample
# Copy this file to .env.local and fill in real keys.
# DO NOT COMMIT .env.local TO SOURCE CONTROL.
# ============================================================

# ----- Application -----
NEXT_PUBLIC_APP_NAME="Alshaya AI Recruit"
NODE_ENV=development
LOG_LEVEL="info"  # error | warn | info | debug

# ----- Database -----
# Provider switch: "sqlite" (local dev) or "postgresql" (Azure / prod).
# When switching, run: npx prisma generate && npx prisma db push
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# ----- Authentication -----
# Provider switch: "local" (mock with bcrypt + signed JWT) or "entra" (Microsoft Entra ID via NextAuth).
AUTH_PROVIDER="local"
# REQUIRED: minimum 32 chars. Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me-in-production-please-32chars-min-________"
AUTH_COOKIE_NAME="alshaya_session"
AUTH_SESSION_TTL_HOURS=168  # 7 days

# Entra ID (only when AUTH_PROVIDER=entra)
ENTRA_TENANT_ID=""
ENTRA_CLIENT_ID=""
ENTRA_CLIENT_SECRET=""

# ----- Storage -----
# Provider switch: "local" (./uploads folder) or "azure-blob".
STORAGE_PROVIDER="local"
LOCAL_STORAGE_PATH="./uploads"
AZURE_BLOB_CONNECTION_STRING=""
AZURE_BLOB_CONTAINER="resumes"

# ----- Queue (long-running scoring jobs) -----
# Provider switch: "memory" (in-process, dev only) or "service-bus" (Azure).
QUEUE_PROVIDER="memory"
AZURE_SERVICE_BUS_CONNECTION_STRING=""
AZURE_SERVICE_BUS_QUEUE="scoring-jobs"

# ============================================================
# AI ENGINES - at least one is recommended for real AI scoring
# If none are configured, the app falls back to local-rule mode
# (clearly labelled in the UI as "LOCAL FALLBACK").
# ============================================================

# ----- Google Gemini (free tier supported) -----
# Get key from: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=""
# Current free-tier flash models (2026): gemini-2.5-flash, gemini-2.5-flash-lite, gemini-3.5-flash.
# Leave blank for auto-detect (recommended) - the app will probe ListModels and pick the best available.
GOOGLE_GEMINI_MODEL="gemini-2.5-flash"

# ----- Azure OpenAI (enterprise) -----
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT="gpt-4o-mini"
AZURE_OPENAI_API_VERSION="2024-08-01-preview"

# ----- Online Search (optional - for benchmark market research) -----
# Tavily (recommended): https://tavily.com
TAVILY_API_KEY=""

# ----- Azure Document Intelligence (optional - for scanned PDF OCR) -----
AZURE_DOC_INTELLIGENCE_ENDPOINT=""
AZURE_DOC_INTELLIGENCE_KEY=""

# ----- Copilot Studio (optional - enterprise integration) -----
COPILOT_STUDIO_WEBHOOK_URL=""
COPILOT_STUDIO_API_KEY=""

# ----- Observability (optional) -----
# Azure Application Insights connection string. Leave blank for console-only logging.
APPLICATIONINSIGHTS_CONNECTION_STRING=""

# ----- Rate limiting (production hardening) -----
# Optional Upstash Redis for distributed rate limiting. Leave blank to use in-memory.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
